# MongoDB connection (Atlas SRV string or local mongodb://127.0.0.1:27017)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=jss

# Server
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_ORIGINS=http://localhost:5173

# Secret used to sign/verify admin JWTs (REQUIRED). Generate with: openssl rand -hex 32
JWT_SECRET=

# JWT lifetime (optional, default "15d")
JWT_EXPIRES_IN=15d

# Cloudinary — used only to sign direct-from-browser uploads (server-side secret,
# never sent to the browser). Get these from the Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Upload folder (optional, default "jss")
CLOUDINARY_FOLDER=jss

# Used only by `npm run create-admin` when --email/--password flags are omitted
ADMIN_EMAIL=
ADMIN_PASSWORD=
